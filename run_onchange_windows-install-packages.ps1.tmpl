# Install Windows winget packages

$ErrorActionPreference = "Stop"

function Get-WingetList {
    <#
        .SYNOPSIS
        Retrieves installed packages from from Winget.

        .DESCRIPTION
        Each installed package is returned as a PSCustomObject containing the package
        name, package identifier, installed version, and available update version.

        .EXAMPLE
        Get-WingetList

        Retrieve all winget installed packages

        .EXAMPLE
        Get-WingetList | Where-Object Name -like "*Git*"

        Filter for installed packages by name

        .NOTES
        This function parses the table output from `winget list --source winget`.
        The parser relies on the column layout generated by WinGet.
    #>
    [OutputType([PSCustomObject])]
    param()

    $wingetOutput = winget list --source winget
    $header = $wingetOutput[0]

    $packageNameIndex = $header.IndexOf('Name')
    $packageIdIndex = $header.IndexOf('Id')
    $packageVersionIndex = $header.IndexOf('Version')
    $packageAvailableIndex = $header.IndexOf('Available')

    $data = $wingetOutput | Select-Object -Skip 2
    $packages = foreach ($line in $data) {

        # Skip null or whitespace entries
        if ([string]::IsNullOrWhiteSpace($line)) {
            continue
        }

        $name = $line.Substring($packageNameIndex, $packageIdIndex - $packageNameIndex).Trim()
        $id = $line.Substring($packageIdIndex, $packageVersionIndex - $packageIdIndex).Trim()
        $version = $line.Substring($packageVersionIndex, $packageAvailableIndex - $packageVersionIndex).Trim()
        $available = $line.Substring($packageAvailableIndex).Trim()

        [PSCustomObject]@{
            Name      = $name
            Id        = $id
            Version   = $version
            Available = $available
        }
    }

    return $packages
}

$desiredPackageIds = @(
{{- range .packages.windows.winget }}
    "{{ . }}"
{{- end}}
)

Clear-Host

Write-Host 'Checking installed packages...'

$installedPackages = Get-WingetList
$installedPackageIds = $installedPackages.Id
foreach ($packageId in $desiredPackageIds) {
    # Check if package is already installed.
    # If package already installed skip; otherwise install.
    if ($installedPackageIds -Contains $packageId) {
        Write-Host "$packageId is already installed: Skipping" -ForegroundColor Green
        continue
    }

    Write-Host "Installing: $packageId" -ForegroundColor Yellow
    winget install `
        --id $packageId `
        --source winget `
        --silent `
        --accept-package-agreements `
        --accept-source-agreements
}

Write-Host 'Complete!' -ForegroundColor Blue